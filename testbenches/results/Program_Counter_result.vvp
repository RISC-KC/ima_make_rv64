E_0000019bcf03a940 .event posedge, v0000019bceea1f00_0, v0000019bceea1ac0_0;
    .scope S_0000019bcf0259d0;
T_0 ;
    %wait E_0000019bcf03a940;
    %load/vec4 v0000019bceea1f00_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 64;
    %assign/vec4 v0000019bceea1ce0_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0000019bcf027950_0;
    %assign/vec4 v0000019bceea1ce0_0, 0;
T_0.1 ;
    %jmp T_0;
