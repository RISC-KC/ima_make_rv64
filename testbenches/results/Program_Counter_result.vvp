    .scope S_0000019bceead240;
T_2 ;
    %vpi_call 2 24 "$dumpfile", "testbenches/results/waveforms/Program_Counter_tb_result.vcd" {0 0 0};
    %vpi_call 2 25 "$dumpvars", 32'sb00000000000000000000000000000000, S_0000019bcf0259d0 {0 0 0};
    %vpi_call 2 27 "$display", "==================== Program Counter Test START ====================" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0000019bceeac610_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0000019bcf025b60_0, 0, 1;
    %pushi/vec4 0, 0, 64;
    %store/vec4 v0000019bceeac2e0_0, 0, 64;
    %vpi_call 2 35 "$display", "Reset the PC: " {0 0 0};
    %pushi/vec4 4, 0, 64;
    %store/vec4 v0000019bceeac2e0_0, 0, 64;
    %delay 10000, 0;
    %vpi_call 2 40 "$display", "Before reset: pc = %h", v0000019bceead3d0_0 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0000019bcf025b60_0, 0, 1;
    %pushi/vec4 8, 0, 64;
    %store/vec4 v0000019bceeac2e0_0, 0, 64;
    %delay 10000, 0;
    %vpi_call 2 46 "$display", "After reset = 1, pc = %h", v0000019bceead3d0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0000019bcf025b60_0, 0, 1;
    %delay 10000, 0;
    %vpi_call 2 52 "$display", "\012Assigning value to next_pc: " {0 0 0};
    %pushi/vec4 3735928559, 0, 32;
    %concati/vec4 3735928559, 0, 32;
    %store/vec4 v0000019bceeac2e0_0, 0, 64;
    %delay 10000, 0;
    %vpi_call 2 57 "$display", "pc = %h", v0000019bceead3d0_0 {0 0 0};
    %pushi/vec4 3405692606, 0, 32;
    %concati/vec4 3405692606, 0, 32;
    %store/vec4 v0000019bceeac2e0_0, 0, 64;
    %delay 10000, 0;
    %vpi_call 2 62 "$display", "pc = %h", v0000019bceead3d0_0 {0 0 0};
    %vpi_call 2 65 "$display", "\012Sudden reset:" {0 0 0};
    %delay 5000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0000019bcf025b60_0, 0, 1;
    %delay 5000, 0;
    %vpi_call 2 71 "$display", "pc = %h", v0000019bceead3d0_0 {0 0 0};
    %vpi_call 2 73 "$display", "\012====================  Program Counter Test END  ====================" {0 0 0};
    %vpi_call 2 74 "$stop" {0 0 0};
